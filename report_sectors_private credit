      <table>
        <thead>
          <tr>
            <th>구분</th>
            <th>목표수익률 방향</th>
            <th>Downside protection</th>
            <th>주의할 점</th>
          </tr>
        </thead>

        <tbody>
          <tr>
            <td>우량 선순위 담보대출</td>
            <td>낮음~중간</td>
